# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-app.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-app.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=your-app-id

# AI Provider: cosmiq (free, default) or claude (paid)
VITE_AI_PROVIDER=cosmiq
VITE_HF_SPACE_ID=JNX25/cosmiq-ai-assistant

# Razorpay subscriptions are handled by the Cloud Functions backend (see functions/).
# Only override this if your functions are deployed to a non-default region.
VITE_FIREBASE_FUNCTIONS_REGION=us-central1
